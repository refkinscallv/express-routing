{
    "name": "@refkinscallv/express-routing",
    "version": "3.1.0",
    "description": "Laravel-style routing system for Express.js with CommonJS, ESM, and TypeScript support",
    "keywords": [
        "express",
        "routing",
        "laravel",
        "router",
        "middleware",
        "typescript",
        "esm",
        "commonjs"
    ],
    "homepage": "https://github.com/refkinscallv/express-routing#readme",
    "bugs": {
        "url": "https://github.com/refkinscallv/express-routing/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/refkinscallv/express-routing.git"
    },
    "license": "MIT",
    "author": "Refkinscallv <refkinscallv@gmail.com>",
    "type": "commonjs",
    "main": "index.js",
    "module": "src/routes.mjs",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./types/index.d.mts",
                "default": "./src/routes.mjs"
            },
            "require": {
                "types": "./types/index.d.cts",
                "default": "./index.js"
            }
        }
    },
    "files": [
        "src",
        "types/index.d.ts",
        "types/index.d.mts",
        "types/index.d.cts",
        "index.js",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "npm run test:cjs && npm run test:esm && npm run test:ts",
        "test:cjs": "jest tests/commonjs.test.js",
        "test:esm": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/esm.test.mjs",
        "test:ts": "jest tests/typescript.test.ts",
        "example": "node example/index.js",
        "example:esm": "node example/esm.mjs",
        "example:ts": "ts-node example/typescript.ts",
       "build": "npm run build:check",
        "build:check": "tsc --noEmit && echo TypeScript definitions validated",
        "build:types": "tsc --declaration --emitDeclarationOnly --outDir types --project tsconfig.build.json",
        "prepublishOnly": "npm run build && npm test"
    },
    "dependencies": {
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.2",
        "@types/supertest": "^7.2.0",
        "cross-env": "^10.1.0",
        "jest": "^30.4.2",
        "nodemon": "^3.1.14",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
